{
  "extends": "../../tsconfig.base.json",
  "include": [
    "./*", "../mezon-js-protobuf/abridged_tcp_adapter_pb.ts",
  ],
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "sourceMap": true,
    "module": "es2015",
    "target": "es6",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "dom",
      "es6"
    ],
    "paths": {
      "js-native": ["../js-native/index.js"] 
    },
    "allowJs": true
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../mezon-js-protobuf"
    }
  ]
}